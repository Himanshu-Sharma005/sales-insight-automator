# ============================================================
# Sales Insight Automator – Environment Configuration
# Copy this file to .env and fill in real values
# ============================================================

# ── AI Engine ────────────────────────────────────────────────
# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini model to use (default: gemini-1.5-flash for cost-efficiency)
OPENAI_MODEL=gpt-3.5-turbo

# ── Email Delivery (SMTP) ────────────────────────────────────
# SMTP server host
SMTP_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Sender email address (Gmail: use an App Password, not your real password)
SMTP_USER=your_email@gmail.com

# App password (Gmail: Settings > Security > App passwords)
SMTP_PASSWORD=your_app_password_here

# Display name for the "From" field
FROM_NAME=Sales Insight Automator

# ── Application ──────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated, use * for development only)
# Example: https://your-app.vercel.app,https://www.yourcompany.com
ALLOWED_ORIGINS=*

# ── Frontend (build-time variable) ──────────────────────────
# Full URL of your deployed backend API
REACT_APP_API_URL=http://localhost:8000
